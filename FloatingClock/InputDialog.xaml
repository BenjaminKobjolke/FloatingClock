<Window x:Class="FloatingClock.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input"
        Width="300"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        KeyDown="InputDialog_KeyDown"
        Loaded="InputDialog_Loaded">

    <Border Background="#CC000000"
            BorderBrush="#40FFFFFF"
            BorderThickness="1"
            CornerRadius="5"
            Padding="10">
        <StackPanel>
            <TextBlock x:Name="TitleText"
                       Text="Enter value"
                       Foreground="#FFFFFF"
                       FontFamily="Consolas"
                       FontSize="14"
                       FontWeight="Bold"
                       Margin="0,0,0,10"
                       HorizontalAlignment="Center"/>

            <TextBox x:Name="InputTextBox"
                     FontFamily="Consolas"
                     FontSize="14"
                     Background="#20FFFFFF"
                     Foreground="#FFFFFF"
                     CaretBrush="#FFFFFF"
                     BorderBrush="#40FFFFFF"
                     BorderThickness="1"
                     Padding="5"
                     HorizontalContentAlignment="Center"/>

            <TextBlock Text="Enter Confirm  |  Esc Cancel"
                       Foreground="#80FFFFFF"
                       FontSize="11"
                       Margin="0,10,0,0"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
